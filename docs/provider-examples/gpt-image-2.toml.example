# OpenAI gpt-image-2 (海外通路 / 自定义渠道 schema 参考)
#
# 这个文件**不会被 install.sh 自动安装**, 它只是一份 schema 参考。
# 用法两种:
#   1) 用户自行添加: 把它拷到 ~/.anything-ppt/providers/gpt-image-2.toml,
#      按下面的字段填好自己的 api_key / base_url / models。
#   2) 让 AI 帮加: 在 AI CLI 里说 "我想加 gpt-image-2 / 我想加 <某 provider>",
#      AI 会按这份 schema 问你要 api_key + base_url + 文档链接 + 模型清单,
#      然后写一份新的 .toml 到 ~/.anything-ppt/providers/.
#
# 自定义渠道 (Replicate / Fal / 个人自建网关 / 任何 OpenAI-compatible 端点) 也是同样:
# 提供文档 + 必需材料, AI 就能按 schema 帮你写一份。
#
# 警告: 不论谁加, **api_key 必须是用户自己提供**。AI 不会替你生成 key, 不会替你保管 key。
# .toml 文件本身已被 .gitignore (~/.anything-ppt/ 不进任何 git 仓库)。

[provider]
name = "gpt-image-2"
display_name = "OpenAI gpt-image-2 (or compatible)"
region = "global"
default = false

[auth]
# 全部留空。skill 启动检测到 api_key / base_url 任一为 "" / "<...>" / "PLACEHOLDER" 都判为未配置。
# 你必须自己填三项: api_key / base_url / docs_url。AI 不替你猜。
api_key = ""
base_url = ""
docs_url = ""

[models]
default = "gpt-image-2"
choices = [
    "gpt-image-2",
    # 自定义渠道把模型 ID 列在这里
]

[defaults]
size = "1536x1024"                      # 16:9 近似
quality = "high"                        # low / medium / high

[capabilities]
image_to_image = true                   # 支持 image edit / variation
max_ref_size_mb = 25
multi_ref = true
billing_on_failure = false

[how_to_use]
# AI 怎么调用这个 provider
# 注意: generate-image skill (generate.py) 的 OpenAI 通路集成是 M2 路线图。
# 现阶段如果你已经填好了 .toml, AI 会按 invoke 模板生成 curl 调用作为 fallback。
invoke = "generate.py --provider {provider.name} --size {size} --quality {quality} --ref {ref} '{prompt}'"
notes = """
- 海外用户首选, 不需要国内账号
- 也适用于任何 OpenAI-compatible 自建网关: 改 base_url 即可
- API 文档: https://platform.openai.com/docs/api-reference/images
"""
